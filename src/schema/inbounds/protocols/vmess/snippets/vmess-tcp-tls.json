{
  "label": "VMess + TCP + TLS",
  "description": "VMess inbound over TCP with TLS",
  "body": {
    "protocol": "vmess",
    "listen": "0.0.0.0",
    "port": 443,
    "tag": "VMESS-TCP-TLS",
    "settings": {
      "clients": []
    },
    "streamSettings": {
      "network": "tcp",
      "security": "tls",
      "tlsSettings": {
        "serverName": "${3:example.com}",
        "alpn": ["http/1.1", "h2"]
      }
    },
    "sniffing": {
      "enabled": true,
      "routeOnly": true,
      "destOverride": ["http", "tls", "quic", "fakedns"]
    }
  }
}
