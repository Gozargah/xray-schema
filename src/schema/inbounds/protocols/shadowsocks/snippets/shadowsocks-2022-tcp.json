{
  "label": "Shadowsocks (2022-blake3-aes-128-gcm)",
  "description": "Shadowsocks 2022 AEAD inbound",
  "body": {
    "protocol": "shadowsocks",
    "listen": "0.0.0.0",
    "port": 8388,
    "tag": "SS-2022-TCP",
    "settings": {
      "network": "tcp,udp",
      "method": "2022-blake3-aes-128-gcm",
      "password": "${1:base64key}",
      "level": 0,
      "users": []
    },
    "sniffing": {
      "enabled": true,
      "routeOnly": true,
      "destOverride": ["http", "tls", "quic", "fakedns"]
    }
  }
}
